# Get these from your Upstash Redis dashboard:
# https://console.upstash.com/redis
#
# 1. Create a free Redis database
# 2. Click "Connect" → ".env.local" tab
# 3. Copy the values below

KV_REST_API_URL=https://YOUR_URL.upstash.io
KV_REST_API_TOKEN=YOUR_TOKEN

# Push notifications via ntfy.sh (optional)
# Pick a hard-to-guess topic name — anyone who knows it can subscribe
NTFY_TOPIC="alan-checkins-x7k2m9"
